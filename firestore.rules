rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { 
      return request.auth != null && request.auth.token.email_verified == true; 
    }

    // Validation helper for AttendanceEntry
    function isValidAttendanceEntry(data) {
      return data.keys().hasAll(['id', 'date', 'name', 'createdAt', 'userId']) &&
             data.keys().size() >= 5 &&
             data.keys().size() <= 11 &&
             data.id is string && data.id.size() <= 128 && data.id.matches('^[a-zA-Z0-9_\\-]+$') &&
             data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid &&
             data.date is string && data.date.size() <= 20 &&
             data.name is string && data.name.size() <= 500 &&
             data.createdAt is number &&
             data.get('timeIn', '') is string && data.get('timeIn', '').size() <= 50 &&
             data.get('timeOut', '') is string && data.get('timeOut', '').size() <= 50 &&
             data.get('status', '') is string && data.get('status', '').size() <= 50 &&
             data.get('notes', '') is string && data.get('notes', '').size() <= 10000 &&
             data.get('jobType', 'daily') is string && data.get('jobType', 'daily') in ['daily', 'contract', 'container'] &&
             (data.get('billed', false) is bool);
    }

    // Rules for User Entries
    match /users/{userId}/entries/{entryId} {
      // Allow read if signed in and checking own user id
      allow get: if isSignedIn() && isValidId(userId) && isValidId(entryId) && userId == request.auth.uid;
      // Secure list query
      allow list: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() && 
                    isValidId(userId) && 
                    isValidId(entryId) && 
                    userId == request.auth.uid && 
                    isValidAttendanceEntry(incoming());

      allow update: if isSignedIn() && 
                    isValidId(userId) && 
                    isValidId(entryId) && 
                    userId == request.auth.uid && 
                    existing().userId == request.auth.uid && 
                    isValidAttendanceEntry(incoming()) && 
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().id == existing().id &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['timeIn', 'timeOut', 'status', 'notes', 'billed', 'name', 'jobType', 'date'])
                    );

      allow delete: if isSignedIn() && isValidId(userId) && isValidId(entryId) && userId == request.auth.uid;
    }
  }
}
